---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="链接我"
  description="随时欢迎交流 AI 落地、跨境增长或职业发展。微信 / 小红书 / X / 邮箱，全渠道链接。"
>

<div class="pt-40 pb-20 px-4">
  <div class="max-w-2xl mx-auto">
    <a href="/" class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors mb-10 group text-sm font-medium">
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      返回首页
    </a>

    <div class="mb-12">
      <h1 class="text-4xl font-extrabold text-white mb-3 tracking-tight">链接我 <span class="text-blue-500">.</span></h1>
      <p class="text-slate-400 text-lg">随时欢迎交流 AI 落地、跨境增长或职业发展。</p>
    </div>

    <div class="space-y-5">
      <!-- 微信 -->
      <button onclick="showWX()" class="w-full flex items-center gap-6 bg-slate-900/50 backdrop-blur-md p-6 rounded-3xl border border-white/5 hover:border-green-500/50 hover:bg-slate-800/80 transition-all group text-left active:scale-[0.98]">
        <div class="w-14 h-14 bg-green-500/10 rounded-2xl flex items-center justify-center text-green-500 group-hover:bg-green-500 group-hover:text-white transition-all duration-300">
          <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24">
            <path d="M8.53 1.95c-3.95 0-7.14 2.87-7.14 6.42 0 1.96 1 3.73 2.59 4.96l-.65 2.19 2.27-1.14c.3.06.6.1.93.1 3.94 0 7.14-2.88 7.14-6.43s-3.2-6.1-7.14-6.1zm-.05 1.7c.45 0 .82.35.82.78 0 .43-.37.78-.82.78-.45 0-.82-.35-.82-.78s.37-.78.82-.78zm-3.1 0c.45 0 .81.35.81.78 0 .43-.36.78-.81.78-.45 0-.82-.35-.82-.78s.37-.78.82-.78zm13.12 4.1c-3.28 0-5.94 2.4-5.94 5.35 0 2.95 2.66 5.35 5.94 5.35.28 0 .54-.03.81-.08l1.89.95-.54-1.83c1.32-1.02 2.16-2.5 2.16-4.14 0-2.95-2.66-5.35-5.94-5.35zm-1.63 1.7c.33 0 .61.26.61.58 0 .32-.28.58-.61.58-.33 0-.61-.26-.61-.58 0-.32.28-.58.61-.58zm2.6 0c.33 0 .61.26.61.58 0 .32-.28.58-.61.58-.34 0-.61-.26-.61-.58 0-.32.27-.58.61-.58z"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-bold text-xl text-white">微信 (WeChat)</h3>
          <p class="text-slate-400 text-sm mt-1 font-mono">ID: Web3hanbaomao</p>
        </div>
        <div class="text-slate-600 group-hover:text-green-500 transition-colors">
          <span class="text-xs font-bold bg-white/5 px-3 py-1 rounded-full border border-white/5 group-hover:bg-green-500/20 group-hover:border-green-500/20">点击扫码</span>
        </div>
      </button>

      <!-- 小红书 -->
      <a href="https://xhslink.com/m/7s9WLtS0fTA" target="_blank" class="w-full flex items-center gap-6 bg-slate-900/50 backdrop-blur-md p-6 rounded-3xl border border-white/5 hover:border-rose-500/50 hover:bg-slate-800/80 transition-all group active:scale-[0.98]">
        <div class="w-14 h-14 bg-rose-500/10 rounded-2xl flex items-center justify-center text-rose-400 group-hover:bg-rose-600 group-hover:text-white transition-all duration-300">
          <svg class="w-8 h-8" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z"></path>
            <path d="M14 2v6h6"></path>
            <path d="M8 13h8"></path>
            <path d="M8 17h8"></path>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-bold text-xl text-white">小红书 (RED)</h3>
          <p class="text-slate-400 text-sm mt-1">Web3汉堡猫</p>
        </div>
        <svg class="w-5 h-5 text-slate-600 group-hover:text-rose-400 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
      </a>

      <!-- X -->
      <a href="https://x.com/Web3hanbaomao" target="_blank" class="w-full flex items-center gap-6 bg-slate-900/50 backdrop-blur-md p-6 rounded-3xl border border-white/5 hover:border-white/30 hover:bg-slate-800/80 transition-all group active:scale-[0.98]">
        <div class="w-14 h-14 bg-black rounded-2xl flex items-center justify-center border border-white/10 group-hover:scale-110 transition-transform duration-300">
          <svg class="w-7 h-7 fill-current text-white" viewBox="0 0 24 24">
            <path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-bold text-xl text-white">X (Twitter)</h3>
          <p class="text-slate-400 text-sm mt-1">@Web3hanbaomao</p>
        </div>
        <svg class="w-5 h-5 text-slate-600 group-hover:text-white transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V8a2 2 0 0 1 2-2h6"></path><polyline points="15 3 21 3 21 9"></polyline><line x1="10" y1="14" x2="21" y2="3"></line></svg>
      </a>

      <!-- 邮箱 -->
      <a href="mailto:chrislee159354@gmail.com" class="w-full flex items-center gap-6 bg-slate-900/50 backdrop-blur-md p-6 rounded-3xl border border-white/5 hover:border-blue-500/50 hover:bg-slate-800/80 transition-all group active:scale-[0.98]">
        <div class="w-14 h-14 bg-blue-500/10 rounded-2xl flex items-center justify-center text-blue-500 group-hover:bg-blue-600 group-hover:text-white transition-all duration-300">
          <svg class="w-8 h-8 fill-current" viewBox="0 0 24 24">
            <path d="M20 4H4c-1.1 0-1.99.9-1.99 2L2 18c0 1.1.9 2 2 2h16c1.1 0 2-.9 2-2V6c0-1.1-.9-2-2-2zm0 4l-8 5-8-5V6l8 5 8-5v2z"/>
          </svg>
        </div>
        <div class="flex-1">
          <h3 class="font-bold text-xl text-white">邮箱 (Email)</h3>
          <p class="text-slate-400 text-sm mt-1 font-mono">chrislee159354@gmail.com</p>
        </div>
        <svg class="w-6 h-6 text-slate-600 group-hover:text-blue-500 transition-colors" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 2L11 13"></path><polygon points="22 2 15 22 11 13 2 9 22 2"></polygon></svg>
      </a>
    </div>

    <div class="mt-16 pt-8 border-t border-white/5 text-center">
      <p class="text-slate-500 text-sm">&copy; {new Date().getFullYear()} Web3汉堡猫. Let's build something cool.</p>
    </div>
  </div>
</div>

<!-- 微信弹窗 -->
<div id="wxModal" class="hidden fixed z-[100] inset-0 bg-black/85 backdrop-blur-lg" style="display:none" onclick="hideWX()">
  <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-slate-800 p-8 rounded-[2rem] max-w-sm w-full text-center border border-white/10 shadow-2xl" onclick="event.stopPropagation()">
    <button onclick="hideWX()" class="absolute top-4 right-4 rounded-full bg-white/5 flex items-center justify-center text-slate-400 hover:bg-white/10 hover:text-white transition-colors">
      <svg class="w-8 h-8" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"></path></svg>
    </button>
    <div class="mb-6">
      <div class="w-16 h-16 bg-green-500/20 text-green-500 rounded-full flex items-center justify-center mx-auto mb-4">
        <svg class="w-10 h-10 fill-current" viewBox="0 0 24 24"><path d="M8.53 1.95c-3.95 0-7.14 2.87-7.14 6.42 0 1.96 1 3.73 2.59 4.96l-.65 2.19 2.27-1.14c.3.06.6.1.93.1 3.94 0 7.14-2.88 7.14-6.43s-3.2-6.1-7.14-6.1zm-.05 1.7c.45 0 .82.35.82.78 0 .43-.37.78-.82.78-.45 0-.82-.35-.82-.78s.37-.78.82-.78zm-3.1 0c.45 0 .81.35.81.78 0 .43-.36.78-.81.78-.45 0-.82-.35-.82-.78s.37-.78.82-.78zm13.12 4.1c-3.28 0-5.94 2.4-5.94 5.35 0 2.95 2.66 5.35 5.94 5.35.28 0 .54-.03.81-.08l1.89.95-.54-1.83c1.32-1.02 2.16-2.5 2.16-4.14 0-2.95-2.66-5.35-5.94-5.35zm-1.63 1.7c.33 0 .61.26.61.58 0 .32-.28.58-.61.58-.33 0-.61-.26-.61-.58 0-.32.28-.58.61-.58zm2.6 0c.33 0 .61.26.61.58 0 .32-.28.58-.61.58-.34 0-.61-.26-.61-.58 0-.32.27-.58.61-.58z"/></svg>
      </div>
      <h3 class="font-bold text-2xl text-white">添加我的微信</h3>
      <p class="text-slate-400 text-sm mt-1">请备注来源 (如: 个人网站)</p>
    </div>
    <div class="bg-white p-2 rounded-xl mb-6">
      <img src="/images/QRcode_Web3hanbaomao.jpg" alt="WeChat QR Code" class="w-full rounded-lg" />
    </div>
    <div class="bg-slate-900/50 p-3 rounded-xl border border-white/5 flex items-center justify-between">
      <span class="text-slate-400 text-sm pl-2">微信号:</span>
      <span class="text-white font-mono font-bold select-all">Web3hanbaomao</span>
    </div>
  </div>
</div>

</BaseLayout>
