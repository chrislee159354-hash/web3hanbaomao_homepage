---
import BaseLayout from '../layouts/BaseLayout.astro';
---

<BaseLayout
  title="首页"
  description="全球 Top5 Web3 交易所运营 | 前云计算产品经理 | Crypto x AI — 分享Web3光鲜外表后真实硬核的职场，热心的内推侠。用AI与Crypto，重构生产力。"
>

<!-- Hero：横版布局 -->
<section class="pt-28 pb-8 px-4 max-w-5xl mx-auto">
  <div class="flex flex-col items-center text-center md:flex-row md:items-center md:justify-between md:text-left md:gap-10">
    <div class="w-24 h-24 md:w-28 md:h-28 rounded-full overflow-hidden border-4 border-white/10 shadow-2xl group relative shrink-0">
      <img src="/images/profile_web3hanbaomao.jpg" alt="Web3汉堡猫 头像" class="w-full h-full object-cover group-hover:scale-110 transition-transform duration-500" />
      <div class="absolute inset-0 bg-gradient-to-t from-darkBg/50 to-transparent"></div>
    </div>
    <div class="mt-6 md:mt-0 flex-1">
      <h1 class="text-4xl md:text-5xl font-extrabold tracking-tight text-white leading-tight">Web3汉堡猫</h1>
      <p class="text-base md:text-lg text-slate-400 font-medium mt-2">全球 Top5 Web3 交易所运营 | 前云计算产品经理 | Crypto x AI</p>
      <p class="text-lg md:text-xl text-slate-200 font-semibold mt-3 leading-snug">分享Web3光鲜外表后，真实硬核的职场，热心的内推侠</p>
      <h2 class="text-xl md:text-2xl font-bold text-transparent bg-clip-text bg-gradient-to-r from-amber-400 via-orange-500 to-amber-400 mt-4">
        用AI与Crypto，重构生产力
      </h2>
    </div>
  </div>
</section>

<!-- 四宫格导航（紧凑版） -->
<section class="pt-3 pb-8 max-w-5xl mx-auto px-4">
  <div class="grid grid-cols-1 md:grid-cols-2 gap-3">
    <a href="/connect" class="block bg-slate-900/40 backdrop-blur-md p-5 rounded-3xl border border-white/5 hover:border-blue-500/50 hover:bg-slate-800/60 transition-all group">
      <div class="flex items-center gap-3.5">
        <div class="p-2.5 bg-blue-500/10 text-blue-400 rounded-2xl group-hover:bg-blue-500 group-hover:text-white transition-all">
          <svg class="w-5 h-5 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24"><path d="M10 13a5 5 0 0 0 7.54.54l3-3a5 5 0 0 0-7.07-7.07l-1.72 1.71"></path><path d="M14 11a5 5 0 0 0-7.54-.54l-3 3a5 5 0 0 0 7.07 7.07l1.71-1.71"></path></svg>
        </div>
        <div>
          <h3 class="font-bold text-lg text-white">链接我 (Connect)</h3>
          <p class="text-slate-400 text-sm mt-0.5">WeChat / 小红书 / X / 职场交流与内推</p>
        </div>
        <svg class="w-4 h-4 ml-auto text-slate-600 group-hover:text-blue-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
      </div>
    </a>

    <a href="/business" class="block bg-slate-900/40 backdrop-blur-md p-5 rounded-3xl border border-white/5 hover:border-purple-500/50 hover:bg-slate-800/60 transition-all group">
      <div class="flex items-center gap-3.5">
        <div class="p-2.5 bg-purple-500/10 text-purple-400 rounded-2xl group-hover:bg-purple-500 group-hover:text-white transition-all">
          <svg class="w-5 h-5 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24"><rect x="2" y="7" width="20" height="14" rx="2" ry="2"></rect><path d="M16 21V5a2 2 0 0 0-2-2h-4a2 2 0 0 0-2 2v16"></path></svg>
        </div>
        <div>
          <h3 class="font-bold text-lg text-white">我的业务 (Business)</h3>
          <p class="text-slate-400 text-sm mt-0.5">交易所运营增长 / Crypto x AI / 资源合作</p>
        </div>
        <svg class="w-4 h-4 ml-auto text-slate-600 group-hover:text-purple-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
      </div>
    </a>

    <a href="/moe" class="block bg-slate-900/40 backdrop-blur-md p-5 rounded-3xl border border-white/5 hover:border-emerald-500/50 hover:bg-slate-800/60 transition-all group">
      <div class="flex items-center gap-3.5">
        <div class="p-2.5 bg-emerald-500/10 text-emerald-400 rounded-2xl group-hover:bg-emerald-500 group-hover:text-white transition-all">
          <svg class="w-5 h-5 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24"><rect x="4" y="4" width="16" height="16" rx="2"></rect><path d="M9 9h6v6H9zM9 1v3M15 1v3M9 20v3M15 20v3M20 9h3M20 15h3M1 9h3M1 15h3"></path></svg>
        </div>
        <div>
          <h3 class="font-bold text-lg text-white">认知架构 (My MOE)</h3>
          <p class="text-slate-400 text-sm mt-0.5">AI 工作流 / 生产力系统 / 可复制的方法论</p>
        </div>
        <svg class="w-4 h-4 ml-auto text-slate-600 group-hover:text-emerald-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
      </div>
    </a>

    <a href="/story" class="block bg-slate-900/40 backdrop-blur-md p-5 rounded-3xl border border-white/5 hover:border-orange-500/50 hover:bg-slate-800/60 transition-all group">
      <div class="flex items-center gap-3.5">
        <div class="p-2.5 bg-orange-500/10 text-orange-400 rounded-2xl group-hover:bg-orange-500 group-hover:text-white transition-all">
          <svg class="w-5 h-5 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"></path><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"></path></svg>
        </div>
        <div>
          <h3 class="font-bold text-lg text-white">Web3 运营思考</h3>
          <p class="text-slate-400 text-sm mt-0.5">一个优秀 Web3 运营的自我修养</p>
        </div>
        <svg class="w-4 h-4 ml-auto text-slate-600 group-hover:text-orange-400 transition-colors" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M5 12h14M12 5l7 7-7 7"></path></svg>
      </div>
    </a>
  </div>
</section>

<!-- CTA -->
<section class="py-32">
  <div class="max-w-4xl mx-auto px-4 text-center">
    <h2 class="text-3xl md:text-4xl font-bold text-white mb-8 leading-tight tracking-tight">
      想看见 Web3 职场的真实一面，或者需要内推与资源链接？<br class="hidden md:block" />欢迎来聊，一起把机会变得可复制
    </h2>
    <div class="flex flex-wrap justify-center gap-5 mt-12">
      <a href="https://x.com/Web3hanbaomao" target="_blank" class="flex items-center gap-3 bg-black text-white border border-white/10 px-8 py-4 rounded-full font-bold hover:bg-slate-900 transition-all hover:scale-105 active:scale-95">
        <svg class="w-5 h-5 fill-current" viewBox="0 0 24 24"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231zm-1.161 17.52h1.833L7.084 4.126H5.117z"></path></svg>
        X 主页
      </a>
      <button onclick="showWX()" class="flex items-center gap-3 bg-green-500 text-white px-8 py-4 rounded-full font-bold hover:bg-green-400 transition-all hover:scale-105 active:scale-95">
        <svg class="w-6 h-6 fill-current text-white" viewBox="0 0 24 24"><path d="M8.53 1.95c-3.95 0-7.14 2.87-7.14 6.42 0 1.96 1 3.73 2.59 4.96l-.65 2.19 2.27-1.14c.3.06.6.1.93.1 3.94 0 7.14-2.88 7.14-6.43s-3.2-6.1-7.14-6.1zm-.05 1.7c.45 0 .82.35.82.78 0 .43-.37.78-.82.78-.45 0-.82-.35-.82-.78s.37-.78.82-.78zm-3.1 0c.45 0 .81.35.81.78 0 .43-.36.78-.81.78-.45 0-.82-.35-.82-.78s.37-.78.82-.78zm13.12 4.1c-3.28 0-5.94 2.4-5.94 5.35 0 2.95 2.66 5.35 5.94 5.35.28 0 .54-.03.81-.08l1.89.95-.54-1.83c1.32-1.02 2.16-2.5 2.16-4.14 0-2.95-2.66-5.35-5.94-5.35zm-1.63 1.7c.33 0 .61.26.61.58 0 .32-.28.58-.61.58-.33 0-.61-.26-.61-.58 0-.32.28-.58.61-.58zm2.6 0c.33 0 .61.26.61.58 0 .32-.28.58-.61.58-.34 0-.61-.26-.61-.58 0-.32.27-.58.61-.58z"/></svg>
        微信联系
      </button>
    </div>
  </div>
</section>

<!-- 微信弹窗 -->
<div id="wxModal" class="hidden fixed z-[100] inset-0 bg-black/85 backdrop-blur-lg" style="display:none" onclick="hideWX()">
  <div class="fixed top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 bg-slate-800 p-8 rounded-3xl w-[320px] text-center border border-white/10 shadow-2xl" onclick="event.stopPropagation()">
    <button onclick="hideWX()" class="absolute top-4 right-4 text-slate-500 hover:text-white transition-colors">
      <svg class="w-6 h-6" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M18 6L6 18M6 6l12 12"></path></svg>
    </button>
    <h3 class="font-bold text-xl mb-5 text-white">添加我的微信</h3>
    <img src="/images/QRcode_Web3hanbaomao.jpg" alt="WeChat QR" class="w-full rounded-2xl mb-5 border border-white/5 shadow-inner" />
    <p class="text-slate-400 text-sm">WeChat：<span class="text-white font-mono">Web3hanbaomao</span></p>
    <p class="text-slate-400 text-sm mt-2">小红书：<span class="text-white font-mono">Web3汉堡猫</span></p>
  </div>
</div>

</BaseLayout>
