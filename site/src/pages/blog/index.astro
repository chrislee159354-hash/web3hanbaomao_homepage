---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

// 分类中文名
const categoryNames: Record<string, { name: string; color: string }> = {
  ai: { name: 'AI与杠杆', color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
  web3: { name: 'Web3思考', color: 'text-amber-400 bg-amber-500/10 border-amber-500/20' },
  'first-principles': { name: '第一性原理', color: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20' },
  'ops-basics': { name: 'Web3运营入门', color: 'text-blue-400 bg-blue-500/10 border-blue-500/20' },
  'data-analysis': { name: '数据分析实战', color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
  'good-ops': { name: '什么是好的运营', color: 'text-emerald-400 bg-emerald-500/10 border-emerald-500/20' },
  interview: { name: '面试题库', color: 'text-purple-400 bg-purple-500/10 border-purple-500/20' },
};
---

<BaseLayout
  title="全部文章"
  description="Web3汉堡猫的全部文章目录。AI、Web3、运营思考、面试题库——持续更新中。"
>

<div class="pt-28 pb-20 px-4">
  <div class="max-w-4xl mx-auto">

    <a href="/" class="inline-flex items-center gap-2 text-slate-400 hover:text-white transition-colors mb-10 group text-sm font-medium">
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      返回首页
    </a>

    <div class="mb-12">
      <h1 class="text-4xl font-extrabold text-white mb-3 tracking-tight">全部文章</h1>
      <p class="text-slate-400 text-lg">共 {allPosts.length} 篇，持续更新中。</p>
    </div>

    {allPosts.length === 0 ? (
      <p class="text-slate-600 text-lg italic text-center py-20">还没有文章，写第一篇？</p>
    ) : (
      <div class="grid grid-cols-1 gap-4">
        {allPosts.map(post => {
          const { title, description, category, date: pubDate } = post.data;
          const cat = categoryNames[category] || { name: category, color: 'text-slate-400 bg-slate-500/10 border-slate-500/20' };
          return (
            <a href={`/blog/${post.slug}`} class="block bg-slate-900/40 backdrop-blur-md rounded-2xl border border-white/5 hover:border-white/10 hover:bg-slate-800/60 transition-all group p-6">
              <div class="flex items-start gap-4">
                <div class="flex-1 min-w-0">
                  <div class="flex items-center gap-3 mb-2">
                    <span class={`text-[10px] font-bold tracking-widest uppercase px-2.5 py-1 rounded-full border ${cat.color}`}>{cat.name}</span>
                    <span class="text-slate-600 text-xs">{pubDate.toLocaleDateString('zh-CN', { year: 'numeric', month: 'long', day: 'numeric' })}</span>
                  </div>
                  <h2 class="text-lg font-bold text-white group-hover:text-blue-400 transition-colors mb-1 leading-snug">{title}</h2>
                  <p class="text-slate-500 text-sm leading-relaxed line-clamp-2">{description}</p>
                </div>
                <svg class="w-5 h-5 text-slate-600 group-hover:text-blue-400 transition-colors shrink-0 mt-1" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path d="M9 5l7 7-7 7"></path></svg>
              </div>
            </a>
          );
        })}
      </div>
    )}
  </div>
</div>

</BaseLayout>
