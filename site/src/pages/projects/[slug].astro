---
import { getCollection } from 'astro:content';
import BaseLayout from '../../layouts/BaseLayout.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects', ({ data }) => !data.draft);
  return projects.map((project) => ({
    params: { slug: project.slug },
    props: { project },
  }));
}

const { project } = Astro.props;
const { title, description, image, tags } = project.data;
const { Content } = await project.render();

const primaryTag = tags[0] || 'Project';
const colors: Record<string, { bg: string; text: string; border: string }> = {
  '示例': { bg: 'bg-slate-500/10', text: 'text-slate-400', border: 'border-slate-500/20' },
};
const c = colors[primaryTag] ?? { bg: 'bg-blue-500/10', text: 'text-blue-400', border: 'border-blue-500/20' };
---

<BaseLayout title={title} description={description} image={image} ogType="article">
  <div class="pt-28 pb-20 px-4">
    <div class="max-w-4xl mx-auto">
      <a href="/#projects" class="inline-flex items-center gap-2 text-slate-500 hover:text-white transition-colors mb-12 group text-sm font-medium">
        <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
        返回项目列表
      </a>

      <div class="mb-16 border-b border-white/10 pb-10">
        <div class="flex items-center gap-3 mb-4">
          {tags.map((tag: string) => (
            <span class={`${c.bg} ${c.text} text-xs font-bold rounded-full uppercase tracking-wider px-3 py-1 border ${c.border}`}>{tag}</span>
          ))}
        </div>
        <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-6 tracking-tight">{title}</h1>
        <p class="text-slate-400 text-lg leading-relaxed max-w-3xl">{description}</p>
      </div>

      <article class="prose prose-invert prose-slate max-w-none
        prose-headings:text-white
        prose-h2:text-2xl prose-h2:font-bold prose-h2:mt-16 prose-h2:mb-6
        prose-h3:text-xl prose-h3:font-semibold
        prose-p:text-slate-300 prose-p:leading-relaxed
        prose-strong:text-white
        prose-img:rounded-3xl prose-img:border prose-img:border-white/10
        prose-a:text-blue-400
        prose-li:text-slate-300
      ">
        <Content />
      </article>
    </div>
  </div>
</BaseLayout>
