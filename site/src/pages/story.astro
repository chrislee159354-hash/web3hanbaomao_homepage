---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allPosts = await getCollection('blog', ({ data }) => !data.draft);
allPosts.sort((a, b) => b.data.date.getTime() - a.data.date.getTime());

const getPosts = (cat: string) => allPosts.filter(p => p.data.category === cat);
const basicsPosts = getPosts('ops-basics');
const dataPosts = getPosts('data-analysis');
const goodOpsPosts = getPosts('good-ops');
---

<BaseLayout
  title="运营能力思考"
  description="一个优秀的Web3运营的自我修养。Web3运营入门、数据分析实战、什么是好的运营？"
>

<div class="pt-28 pb-20 px-4">
  <div class="max-w-5xl mx-auto">

    <a href="/" class="inline-flex items-center gap-2 text-slate-500 hover:text-white transition-colors mb-12 group text-sm font-medium">
      <svg class="w-4 h-4 transition-transform group-hover:-translate-x-1" fill="none" stroke="currentColor" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M10 19l-7-7m0 0l7-7m-7 7h18"></path></svg>
      返回首页
    </a>

    <div class="mb-14 text-center md:text-left">
      <h1 class="text-4xl md:text-5xl font-extrabold text-white mb-5 tracking-tight">运营能力思考 <span class="text-blue-500">.</span> <span class="text-base font-semibold text-slate-500">(Operation Insights)</span></h1>
      <p class="text-slate-400 text-lg leading-relaxed max-w-2xl mx-auto md:mx-0">
        一个优秀的Web3运营的自我修养。文章持续更新。
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
      <!-- Web3 运营入门 -->
      <div class="bg-slate-900/50 backdrop-blur-md border border-white/5 rounded-[2rem] p-8 hover:border-blue-500/50 hover:bg-slate-800/80 transition-all duration-300 group flex flex-col">
        <div class="w-14 h-14 bg-blue-500/10 rounded-2xl flex items-center justify-center text-blue-400 mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M3 17l6-6 4 4 7-9"></path>
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 7v6h-6"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-1">Web3 运营入门</h3>
        <p class="text-sm text-slate-500 mb-6">Web3 Operations Basics</p>

        {basicsPosts.length === 0 ? (
          <p class="text-slate-600 text-sm italic mb-8 flex-1">还没有文章，写第一篇？</p>
        ) : (
          <ul class="space-y-3 mb-8 flex-1">
            {basicsPosts.map(post => (
              <li>
                <a href={`/blog/${post.slug}`} class="block text-sm group/link">
                  <span class="text-slate-300 group-hover/link:text-blue-400 transition-colors leading-snug">{post.data.title}</span>
                  <span class="text-slate-600 text-xs mt-0.5 block">{post.data.date.toLocaleDateString('zh-CN')}</span>
                </a>
              </li>
            ))}
          </ul>
        )}

        <a href="/blog" class="inline-flex items-center justify-center bg-white/5 border border-white/10 rounded-2xl px-5 py-3 text-sm font-bold text-white hover:bg-blue-500/10 hover:border-blue-500/30 transition-all mt-auto">查看全部 &rarr;</a>
      </div>

      <!-- 数据分析实战 -->
      <div class="bg-slate-900/50 backdrop-blur-md border border-white/5 rounded-[2rem] p-8 hover:border-purple-500/50 hover:bg-slate-800/80 transition-all duration-300 group flex flex-col">
        <div class="w-14 h-14 bg-purple-500/10 rounded-2xl flex items-center justify-center text-purple-400 mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 19V5"></path>
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 19h16"></path>
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 16V11"></path>
            <path stroke-linecap="round" stroke-linejoin="round" d="M12 16V7"></path>
            <path stroke-linecap="round" stroke-linejoin="round" d="M16 16V13"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-1">数据分析实战</h3>
        <p class="text-sm text-slate-500 mb-6">Data-driven Operations</p>

        {dataPosts.length === 0 ? (
          <p class="text-slate-600 text-sm italic mb-8 flex-1">还没有文章，写第一篇？</p>
        ) : (
          <ul class="space-y-3 mb-8 flex-1">
            {dataPosts.map(post => (
              <li>
                <a href={`/blog/${post.slug}`} class="block text-sm group/link">
                  <span class="text-slate-300 group-hover/link:text-purple-400 transition-colors leading-snug">{post.data.title}</span>
                  <span class="text-slate-600 text-xs mt-0.5 block">{post.data.date.toLocaleDateString('zh-CN')}</span>
                </a>
              </li>
            ))}
          </ul>
        )}

        <a href="/blog" class="inline-flex items-center justify-center bg-white/5 border border-white/10 rounded-2xl px-5 py-3 text-sm font-bold text-white hover:bg-purple-500/10 hover:border-purple-500/30 transition-all mt-auto">查看全部 &rarr;</a>
      </div>

      <!-- 什么是好的运营 -->
      <div class="bg-slate-900/50 backdrop-blur-md border border-white/5 rounded-[2rem] p-8 hover:border-emerald-500/50 hover:bg-slate-800/80 transition-all duration-300 group flex flex-col">
        <div class="w-14 h-14 bg-emerald-500/10 rounded-2xl flex items-center justify-center text-emerald-400 mb-6 group-hover:scale-110 transition-transform">
          <svg class="w-8 h-8 fill-none stroke-current" stroke-width="2" viewBox="0 0 24 24">
            <path stroke-linecap="round" stroke-linejoin="round" d="M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path>
            <path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01"></path>
          </svg>
        </div>
        <h3 class="text-2xl font-bold text-white mb-1">什么是好的运营？</h3>
        <p class="text-sm text-slate-500 mb-6">What Makes Great Ops</p>

        {goodOpsPosts.length === 0 ? (
          <p class="text-slate-600 text-sm italic mb-8 flex-1">还没有文章，写第一篇？</p>
        ) : (
          <ul class="space-y-3 mb-8 flex-1">
            {goodOpsPosts.map(post => (
              <li>
                <a href={`/blog/${post.slug}`} class="block text-sm group/link">
                  <span class="text-slate-300 group-hover/link:text-emerald-400 transition-colors leading-snug">{post.data.title}</span>
                  <span class="text-slate-600 text-xs mt-0.5 block">{post.data.date.toLocaleDateString('zh-CN')}</span>
                </a>
              </li>
            ))}
          </ul>
        )}

        <a href="/blog" class="inline-flex items-center justify-center bg-white/5 border border-white/10 rounded-2xl px-5 py-3 text-sm font-bold text-white hover:bg-emerald-500/10 hover:border-emerald-500/30 transition-all mt-auto">查看全部 &rarr;</a>
      </div>
    </div>

    <div class="mt-24 text-center">
      <p class="text-slate-500 italic mb-8">"把运营拆开看清楚，把增长做得可复制。"</p>
      <a href="/connect" class="inline-flex items-center gap-3 bg-white text-darkBg px-10 py-4 rounded-full font-bold hover:bg-slate-200 transition-all hover:scale-105 active:scale-95 shadow-xl shadow-white/10">
        <svg class="w-5 h-5" fill="none" stroke="currentColor" stroke-width="2" viewBox="0 0 24 24"><path stroke-linecap="round" stroke-linejoin="round" d="M8 12h.01M12 12h.01M16 12h.01M21 12c0 4.418-4.03 8-9 8a9.863 9.863 0 01-4.255-.949L3 20l1.395-3.72C3.512 15.042 3 13.574 3 12c0-4.418 4.03-8 9-8s9 3.582 9 8z"></path></svg>
        和我聊聊 (Let's Connect)
      </a>
    </div>
  </div>
</div>

</BaseLayout>
